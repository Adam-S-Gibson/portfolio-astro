---
interface Props {
  title: string;
  tagline?: string;
  align?: "start" | "center";
}

const { align = "center", tagline, title } = Astro.props;
---

<header class:list={["hero stack gap-4", align]}>
  <slot name="before" />
  <div class="stack gap-2">
    <h1 class="title">
      <span class="output">{title}</span>
    </h1>
    {tagline && <p class="tagline">{tagline}</p>}
  </div>
  <slot />
</header>

<style>
  .hero {
    font-size: var(--text-md);
    text-align: center;
  }

  .start { text-align: start; }

  .title {
    font-size: var(--text-3xl);
    color: var(--fg-bright);
    line-height: 1.1;
    word-break: break-word;
  }

  .start .title,
  .start .tagline {
    margin-inline: 0;
  }

  .tagline {
    color: var(--fg-dim);
    max-width: 60ch;
    margin-inline: auto;
  }

  .start .tagline { margin-inline: 0; }

  @media (min-width: 50em) {
    .hero { font-size: var(--text-md); }
    .title { font-size: var(--text-4xl); }
  }
</style>
