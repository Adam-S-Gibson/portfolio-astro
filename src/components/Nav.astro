---
import Icon, { type Props as IconProps } from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";

const textLinks: { label: string; href: string; cmd: string }[] = [
  { label: "home", href: "/", cmd: "cd ~" },
  { label: "work", href: "/work/", cmd: "ls work/" },
  { label: "about", href: "/about/", cmd: "cat about.md" },
];

const iconLinks: { label: string; href: string; icon: IconProps["icon"] }[] = [
  { label: "GitHub", href: "https://github.com/Adam-S-Gibson", icon: "github-logo" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/adamstevengibson/", icon: "linkedin-logo" },
];

const path = Astro.url.pathname;
const cwd = path === "/" ? "~" : `~${path.replace(/\/$/, "")}`;
---

<nav class="termnav">
  <div class="bar">
    <span class="dots" aria-hidden="true">
      <i></i><i></i><i></i>
    </span>
    <a href="/" class="title">
      <span class="u">adam</span><span class="at">@</span><span class="h">portfolio</span><span class="s">:</span><span class="p">{cwd}</span>
      <span class="s"> &mdash; zsh</span>
    </a>
    <menu-button>
      <template>
        <button class="menu-button" aria-expanded="false">
          <span class="sr-only">Menu</span>
          <span aria-hidden="true">[ menu ]</span>
        </button>
      </template>
    </menu-button>
  </div>

  <div id="menu-content" class="menu">
    <ul class="links">
      {
        textLinks.map(({ label, href, cmd }) => {
          const active = path === href || (href !== "/" && path.startsWith(href));
          return (
            <li>
              <a
                href={href}
                aria-current={active ? "page" : undefined}
                class:list={["link", { active }]}
              >
                <span class="prefix">$</span>
                <span class="cmd">{cmd}</span>
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="meta">
      <div class="socials">
        {
          iconLinks.map(({ href, icon, label }) => (
            <a href={href} class="social" target="_blank" rel="noopener">
              <span class="sr-only">{label}</span>
              <Icon icon={icon} />
            </a>
          ))
        }
      </div>
      <div class="theme-toggle">
        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>

<script>
  class MenuButton extends HTMLElement {
    constructor() {
      super();
      this.appendChild(this.querySelector("template")!.content.cloneNode(true));
      const btn = this.querySelector("button")!;
      const menu = document.getElementById("menu-content")!;
      menu.hidden = true;

      const setExpanded = (expand: boolean) => {
        btn.setAttribute("aria-expanded", expand ? "true" : "false");
        menu.hidden = !expand;
      };

      btn.addEventListener("click", () => setExpanded(menu.hidden));

      const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
        setExpanded(e.matches);
        btn.hidden = e.matches;
      };
      const mq = window.matchMedia("(min-width: 50em)");
      handleViewports(mq);
      mq.addEventListener("change", handleViewports);
    }
  }
  customElements.define("menu-button", MenuButton);
</script>

<style>
  .termnav {
    position: relative;
    z-index: 50;
    font-family: var(--font-mono);
    border-bottom: 1px solid var(--rule);
    background: var(--bg-window-bar);
  }

  .bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 1rem;
    min-height: 2.25rem;
  }

  .dots {
    display: inline-flex;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .dots i {
    display: inline-block;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999rem;
  }
  .dots i:nth-child(1) { background: #ff5f56; }
  .dots i:nth-child(2) { background: #ffbd2e; }
  .dots i:nth-child(3) { background: #27c93f; }

  .title {
    flex: 1;
    text-align: center;
    text-decoration: none;
    color: var(--fg-dim);
    font-size: var(--text-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .title:hover { color: var(--fg-bright); }
  .title .u { color: var(--phosphor-soft); font-weight: 600; }
  .title .h { color: var(--cyan); }
  .title .p { color: var(--amber); }
  .title .s { color: var(--fg-mute); }
  .title .at { color: var(--fg-mute); }

  .menu-button {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0.25rem 0.6rem;
    cursor: pointer;
    border-radius: 0;
  }
  .menu-button[aria-expanded="true"] {
    background: var(--phosphor-trace);
    color: var(--fg-bright);
  }
  .menu-button[hidden] { display: none; }

  .menu {
    border-top: 1px dashed var(--rule);
    background: var(--bg-window);
    padding: 0.75rem 1rem 1rem;
  }

  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .link {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.35rem 0.5rem;
    color: var(--fg-dim);
    text-decoration: none;
    font-size: var(--text-sm);
    border: 1px solid transparent;
  }
  .link .prefix { color: var(--phosphor-soft); }
  .link .cmd { color: var(--fg); }
  .link:hover,
  .link:focus-visible {
    background: var(--phosphor-trace);
    color: var(--fg-bright);
  }
  .link:hover .cmd,
  .link:focus-visible .cmd { color: var(--fg-bright); }
  .link.active {
    border-color: var(--phosphor-soft);
    background: var(--phosphor-trace);
  }
  .link.active .cmd { color: var(--fg-bright); }
  .link.active::before {
    content: "▸";
    color: var(--phosphor-soft);
    margin-right: -0.25rem;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--rule);
  }

  .socials {
    display: flex;
    gap: 0.5rem;
    font-size: var(--text-md);
  }
  .social {
    color: var(--fg-dim);
    display: inline-flex;
    padding: 0.25rem;
    text-decoration: none;
  }
  .social:hover, .social:focus-visible { color: var(--phosphor-soft); }

  @media (min-width: 50em) {
    .bar { padding: 0.55rem 1.25rem; }

    .menu {
      border-top: 1px solid var(--rule);
      padding: 0.45rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .links {
      flex-direction: row;
      gap: 1rem;
    }

    .link {
      padding: 0.2rem 0.5rem;
    }

    .meta {
      margin: 0;
      padding: 0;
      border: 0;
    }
  }
</style>
