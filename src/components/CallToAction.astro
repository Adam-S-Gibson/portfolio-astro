---
interface Props {
  href: string;
}

const { href } = Astro.props;
const external = /^(https?:|mailto:|tel:)/.test(href);
---

<a
  href={href}
  class="cta"
  data-cta
  {...external ? { target: "_blank", rel: "noopener" } : {}}
>
  <span class="bracket" aria-hidden="true">[</span>
  <span class="prompt" aria-hidden="true">$</span>
  <span class="label"><slot /></span>
  <span class="bracket" aria-hidden="true">]</span>
</a>

<style>
  a.cta {
    position: relative;
    display: inline-flex !important;
    align-items: center;
    gap: 0.55ch;
    padding: 0.55em 0.9em;
    font-family: var(--font-mono);
    font-size: var(--text-md);
    line-height: 1.1;
    color: var(--fg-bright) !important;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border: 1px solid var(--phosphor-soft) !important;
    border-radius: 0 !important;
    text-decoration: none !important;
    white-space: nowrap;
    cursor: pointer;
    box-shadow: none;
    transition: background-color var(--theme-transition),
      color var(--theme-transition);
  }

  a.cta .prompt,
  a.cta .bracket {
    color: var(--phosphor-soft);
  }

  a.cta .label {
    color: var(--fg-bright);
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
  }

  a.cta:hover,
  a.cta:focus-visible {
    background: var(--phosphor-soft) !important;
    color: var(--bg) !important;
    text-decoration: none !important;
  }

  a.cta:hover .prompt,
  a.cta:focus-visible .prompt,
  a.cta:hover .bracket,
  a.cta:focus-visible .bracket,
  a.cta:hover .label,
  a.cta:focus-visible .label {
    color: var(--bg);
  }

  /* Kill any inherited overlay from older template styles */
  a.cta::before,
  a.cta::after { content: none !important; display: none !important; }
</style>
