---
---

<theme-toggle>
  <button type="button" aria-pressed="false">
    <span class="sr-only">Toggle dark phosphor theme</span>
    <span aria-hidden="true" class="lbl">[ <span class="state">paper</span> ]</span>
  </button>
</theme-toggle>

<style>
  button {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0.25rem 0.6rem;
    cursor: pointer;
    border-radius: 0;
    transition: color var(--theme-transition), border-color var(--theme-transition);
  }

  button:hover,
  button:focus-visible {
    color: var(--phosphor-soft);
    border-color: var(--phosphor-soft);
  }

  .state { color: var(--fg); }
  button:hover .state, button:focus-visible .state { color: var(--phosphor-soft); }
</style>

<script>
  class ThemeToggle extends HTMLElement {
    constructor() {
      super();
      const button = this.querySelector("button")!;
      const state = this.querySelector(".state")!;

      const setTheme = (dark: boolean) => {
        document.documentElement.classList[dark ? "add" : "remove"]("theme-dark");
        button.setAttribute("aria-pressed", String(dark));
        state.textContent = dark ? "phosphor" : "paper";
      };

      button.addEventListener("click", () => setTheme(!this.isDark()));
      setTheme(this.isDark());
    }

    isDark() {
      return document.documentElement.classList.contains("theme-dark");
    }
  }
  customElements.define("theme-toggle", ThemeToggle);
</script>
