---
import type { CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";

interface Props {
  project: CollectionEntry<"work">;
}

const { data, id } = Astro.props.project;
const date = new Intl.DateTimeFormat("en-GB", {
  year: "numeric",
  month: "short",
  day: "2-digit",
}).format(data.publishDate);
const slug = `${id}.md`;
const tag = data.tags?.[0] ?? "project";
---

<a class="row" href={`/work/${id}`}>
  <span class="perm">-rw-r--r--</span>
  <span class="owner">adam</span>
  <span class="group">staff</span>
  <span class="date">{date}</span>
  <span class="name">
    <span class="path">work/{slug}</span>
  </span>
  <span class="tag">[{tag}]</span>

  <span class="thumb" aria-hidden="true">
    <Picture
      src={data.img}
      alt=""
      formats={["avif", "webp"]}
      fallbackFormat="webp"
      quality={82}
      widths={[480, 720, 1080, 1440, 1920]}
      sizes="(min-width: 80em) 1100px, (min-width: 50em) 80vw, 100vw"
      loading="lazy"
      decoding="async"
    />
  </span>
</a>

<style>
  .row {
    position: relative;
    display: grid;
    grid-template-columns:
      auto auto auto auto minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 1ch;
    row-gap: 0.25rem;
    padding: 0.6rem 0.8rem;
    border-bottom: 1px dashed var(--rule);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg-dim);
    text-decoration: none;
    background: transparent;
    transition: background-color var(--theme-transition);
  }

  .row:hover,
  .row:focus-visible {
    background: var(--phosphor-trace);
    text-decoration: none;
  }

  .row::before {
    content: "$ cat ";
    color: var(--phosphor-soft);
    opacity: 0;
    position: absolute;
    left: -5.5ch;
    top: 0.6rem;
    transition: opacity var(--theme-transition);
  }
  .row:hover::before, .row:focus-visible::before { opacity: 1; }

  .perm   { color: var(--fg-mute); }
  .owner  { color: var(--cyan); }
  .group  { color: var(--fg-mute); }
  .date   { color: var(--amber); white-space: nowrap; }

  .name {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .path {
    color: var(--phosphor-soft);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tag {
    color: var(--magenta);
    white-space: nowrap;
  }

  .thumb {
    grid-column: 1 / -1;
    margin-top: 0.6rem;
    display: block;
    border: 1px solid var(--rule);
    background: var(--bg-elev);
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .thumb::before {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.18) 3px,
      transparent 4px
    );
    z-index: 1;
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0;
    transition: opacity var(--theme-transition);
  }

  :root.theme-dark .thumb::before { opacity: 0.6; }

  .thumb :global(picture),
  .thumb :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .thumb :global(img) {
    object-fit: cover;
    object-position: top;
    image-rendering: auto;
  }

  :root.theme-dark .thumb :global(img) {
    filter: contrast(1.04) saturate(0.85) brightness(0.92);
  }

  @media (max-width: 49.99em) {
    .row {
      grid-template-columns: auto auto minmax(0, 1fr) auto;
    }
    .perm, .owner, .group { display: none; }
  }
</style>
