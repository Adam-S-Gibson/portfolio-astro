---
const currentYear = new Date().getFullYear();
const built = new Intl.DateTimeFormat("en-GB", {
  year: "numeric",
  month: "short",
  day: "2-digit",
}).format(new Date());
---

<footer>
  <div class="wrapper inner">
    <div class="lines">
      <p>
        <span class="prompt">$</span>
        <span class="cmd">uptime</span>
      </p>
      <p class="out">
        built <span class="val">{built}</span> ·
        astro <span class="val">v5</span> ·
        &copy; <span class="val">{currentYear}</span> Adam Gibson
      </p>
      <p>
        <span class="prompt">$</span>
        <span class="cmd">exit</span>
        <span class="rc">0</span><span class="cursor"></span>
      </p>
    </div>
    <p class="links">
      <a href="https://github.com/Adam-S-Gibson" target="_blank" rel="noopener">github.com/Adam-S-Gibson</a>
    </p>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
    padding: 2rem 0;
    border-top: 1px solid var(--rule);
    background: var(--bg-window-bar);
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .lines { display: flex; flex-direction: column; gap: 0.15rem; }

  .prompt { color: var(--phosphor-soft); }
  .cmd { color: var(--fg); }
  .out { color: var(--fg); }
  .val { color: var(--amber); }
  .rc { color: var(--phosphor-soft); margin-left: 0.5ch; }

  .links a { color: var(--fg-dim); }
  .links a:hover, .links a:focus-visible { color: var(--phosphor-soft); }

  @media (min-width: 50em) {
    .inner { flex-direction: row; justify-content: space-between; align-items: flex-end; }
  }
</style>
