---
import CallToAction from "./CallToAction.astro";
---

<aside class="contact">
  <div class="contact-inner wrapper">
    <div class="lines">
      <p class="line">
        <span class="prompt">$</span>
        <span class="cmd">echo $INTEREST</span>
      </p>
      <p class="line out">Interested in working together?</p>
      <p class="line">
        <span class="prompt">$</span>
        <span class="cmd">mail -s "hello"
          <span class="addr">adamsteven15@gmail.com</span><span class="cursor"></span>
        </span>
      </p>
    </div>
    <CallToAction href="mailto:adamsteven15@gmail.com">send message</CallToAction>
  </div>
</aside>

<style>
  .contact {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--bg-window);
    padding: 2.5rem 0;
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .lines {
    font-family: var(--font-mono);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: var(--text-sm);
    color: var(--fg);
  }

  .line { color: var(--fg); }
  .line.out {
    color: var(--fg-bright);
    font-size: var(--text-xl);
    margin: 0.25rem 0;
  }
  .prompt { color: var(--phosphor-soft); }
  .addr { color: var(--cyan); }
  .cmd { color: var(--fg-bright); }

  @media (min-width: 50em) {
    .contact { padding: 3rem 0; }
    .contact-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 2rem;
    }
    .line.out { font-size: var(--text-2xl); }
  }
</style>
