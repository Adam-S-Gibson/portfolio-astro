---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Picture } from "astro:assets";

import BaseLayout from "../../layouts/BaseLayout.astro";

import ContactCTA from "../../components/ContactCTA.astro";
import Pill from "../../components/Pill.astro";
import CallToAction from "../../components/CallToAction.astro";

interface Props {
  entry: CollectionEntry<"work">;
}

export async function getStaticPaths() {
  const work = await getCollection("work");
  return work.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const date = new Intl.DateTimeFormat("en-GB", {
  year: "numeric",
  month: "short",
  day: "2-digit",
}).format(entry.data.publishDate);
---

<BaseLayout
  title={`${entry.data.title} — Adam Gibson`}
  description={entry.data.description}
  ogType="article"
>
  <div class="stack gap-15">
    <header class="wrapper stack gap-4 head">
      <a class="back-link" href="/work/">&larr; cd ../work</a>

      <p class="term-prompt">
        <span class="u">adam</span><span class="s">@</span><span class="h">portfolio</span><span class="s">:</span><span class="p">~/work</span> <span class="c">$</span> cat {entry.id}.md
      </p>

      <h1 class="title">{entry.data.title}</h1>

      <p class="meta">
        <span class="muted">date:</span> <span class="val">{date}</span>
        <span class="sep">·</span>
        <span class="muted">tags:</span>
        {entry.data.tags.map((t) => <Pill>{t}</Pill>)}
      </p>

      <p class="description">{entry.data.description}</p>
    </header>

    <main class="wrapper">
      <article class="prose stack gap-8">
        {
          entry.data.img && (
            <figure class="hero-img">
              <div class="img-bar">
                <span class="win-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span>{entry.id}.png</span>
              </div>
              {entry.data.link ? (
                <a href={entry.data.link} target="_blank" rel="noopener">
                  <Picture
                    src={entry.data.img}
                    alt={entry.data.img_alt || ""}
                    formats={["avif", "webp"]}
                    fallbackFormat="webp"
                    quality={70}
                    widths={[360, 540, 720, 1080]}
                    sizes="(min-width: 50em) min(65ch, 60vw), 100vw"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                  />
                </a>
              ) : (
                <Picture
                  src={entry.data.img}
                  alt={entry.data.img_alt || ""}
                  formats={["avif", "webp"]}
                  fallbackFormat="webp"
                  quality={70}
                  widths={[360, 540, 720, 1080]}
                  sizes="(min-width: 50em) min(65ch, 60vw), 100vw"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                />
              )}
            </figure>
          )
        }

        <div class="content">
          <Content />
        </div>

        {(entry.data.link || entry.data.github) && (
          <div class="actions">
            {entry.data.link && (
              <CallToAction href={entry.data.link as string}>open project</CallToAction>
            )}
            {entry.data.github && (
              <CallToAction href={entry.data.github as string}>view source</CallToAction>
            )}
          </div>
        )}
      </article>
    </main>

    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .head {
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--rule);
  }

  .back-link {
    color: var(--phosphor-soft);
    text-decoration: none;
    font-size: var(--text-sm);
    align-self: flex-start;
  }
  .back-link:hover { color: var(--fg-bright); }

  .title {
    font-size: var(--text-3xl);
    color: var(--fg-bright);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--fg-dim);
    font-size: var(--text-sm);
  }
  .muted { color: var(--fg-mute); }
  .val { color: var(--amber); }
  .sep { color: var(--fg-mute); }

  .description {
    color: var(--fg);
    max-width: 65ch;
  }

  .prose { max-width: 70ch; margin-inline: auto; }

  .hero-img {
    border: 1px solid var(--rule);
    background: var(--bg-elev);
    margin: 0;
  }
  .img-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    background: var(--bg-window-bar);
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg-dim);
  }
  .hero-img :global(picture),
  .hero-img :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
  :root.theme-dark .hero-img :global(img) {
    mix-blend-mode: screen;
  }

  .content :global(* + *) { margin-top: 1rem; }
  .content :global(h1),
  .content :global(h2),
  .content :global(h3),
  .content :global(h4),
  .content :global(h5) {
    margin: 1.75rem 0 0.5rem;
    color: var(--fg-bright);
  }
  .content :global(h2)::before,
  .content :global(h3)::before {
    content: "## ";
    color: var(--phosphor-soft);
  }
  .content :global(blockquote) {
    border-left: 2px solid var(--phosphor-soft);
    padding-left: 1rem;
    color: var(--fg-bright);
    font-family: var(--font-mono);
  }
  .content :global(blockquote)::before {
    content: "> ";
    color: var(--phosphor-soft);
  }
  .content :global(code) {
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    padding: 0.1rem 0.4rem;
    font-size: 0.9em;
  }
  .content :global(pre) {
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    padding: 1rem;
    overflow-x: auto;
  }
  .content :global(img) {
    border: 1px solid var(--rule);
    background: var(--bg-elev);
  }
  .content :global(a) { color: var(--phosphor-soft); }
  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.5rem;
  }
  .content :global(li::marker) {
    color: var(--phosphor-soft);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
