---
import { Picture } from "astro:assets";

import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import adam from "../assets/adam.avif";

const yearsExperience = new Date().getFullYear() - 2020;

const roles = [
  {
    title: "Software Engineer II",
    company: "Condé Nast",
    location: "London, UK",
    period: "Jan 2025 — present",
    summary:
      "Experimentation and data pipelines powering A/B tests across Vogue, GQ, Wired, and the wider brand portfolio. TypeScript, React, MongoDB, Databricks, Kubernetes, Terraform.",
  },
  {
    title: "Freelance Developer",
    company: "Self-employed",
    location: "Remote, UK",
    period: "Apr 2023 — present",
    summary:
      "Websites and web apps for clients on Squarespace, Shopify, and custom HTML/CSS/JS stacks. Scoping, delivery, and ongoing support.",
  },
  {
    title: "Software Engineer",
    company: "Charter",
    location: "London, UK",
    period: "Mar 2024 — Nov 2024",
    summary:
      "Next.js, React, PostgreSQL, GraphQL. Query tuning, caching, and an RxDB in-memory layer that unblocked offline-capable features.",
  },
  {
    title: "Software Engineer",
    company: "StreetDrone",
    location: "Oxford, UK",
    period: "Oct 2021 — Mar 2023",
    summary:
      "Real-time tracking for remotely operated vehicles on MQTT, Kinesis, Lambda, and DynamoDB, with Vue and React frontends. Multi-AZ Terraform infrastructure.",
  },
  {
    title: "Junior Software Engineer",
    company: "Paradigm",
    location: "Alton, UK",
    period: "Dec 2020 — Oct 2021",
    summary:
      "C# / SignalR backend, Node.js + GraphQL tooling, and a React frontend hardened with Zustand and Zod. First role out of university.",
  },
];

const skillGroups = [
  { label: "languages", items: ["TypeScript", "JavaScript", "Python", "Go", "C#"] },
  { label: "frameworks", items: ["React", "Next.js", "Vue.js", "Redux", "Zustand", "Zod"] },
  { label: "api+data", items: ["GraphQL", "Apollo", "SQL"] },
  { label: "databases", items: ["PostgreSQL", "MySQL", "MongoDB", "Databricks"] },
  { label: "cloud+infra", items: ["AWS", "GCP", "Kubernetes", "Docker", "Terraform"] },
  { label: "devops", items: ["GitHub Actions", "Linux", "Jest"] },
  { label: "ai/llm", items: ["Claude Code", "Codex", "Ollama"] },
];

const education = [
  { degree: "MSc Advanced Computer Science", institution: "Oxford Brookes University", year: "Sep 2019 — Dec 2020" },
  { degree: "BSc Computer Science and Japanese Studies", institution: "Oxford Brookes University", year: "Sep 2015 — Jul 2019" },
];

const mentoring = [
  { title: "Career mentoring in programming", detail: "One-to-one coaching on technical interviews and early-career direction.", period: "Jun 2024 — present" },
  { title: "Computer Science lecturer", detail: "Associate lecturer covering programming, data structures and algorithms, and career advice.", period: "Sep 2019 — Dec 2019" },
];
---

<BaseLayout title="About | Adam Gibson" description="About Adam Gibson">
  <div class="stack gap-15">
    <main class="wrapper about stack gap-10">
      <header class="head stack gap-4">
        <p class="term-prompt">
          <span class="u">adam</span><span class="s">@</span><span class="h">portfolio</span><span class="s">:</span><span class="p">~</span> <span class="c">$</span> cat about.md
        </p>
        <h1>about/</h1>
        <p class="tagline">
          Thanks for stopping by. Read below to learn more about myself and my background.
        </p>
        <figure class="portrait-frame">
          <div class="portrait-bar">
            <span class="win-dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span>adam.avif</span>
          </div>
          <Picture
            src={adam}
            alt="Adam Gibson in a field"
            formats={["avif", "webp"]}
            fallbackFormat="webp"
            quality={65}
            widths={[400, 720, 1080, 1440]}
            sizes="(min-width: 50em) 60vw, 100vw"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </figure>
      </header>

      <section class="block">
        <h2 class="section-title"><span class="hash">##</span> background</h2>
        <div class="content">
          <p>
            Software engineer, {yearsExperience} years in. I'm currently at
            Condé Nast in London, working on the experimentation and data
            pipelines that run A/B tests across Vogue, GQ, Wired, and the
            wider brand portfolio.
          </p>
          <p>
            I started at Paradigm on a C# / SignalR backend, moved to
            StreetDrone building real-time infrastructure for remotely
            operated vehicles on AWS, which is where most of my cloud, database,
            and Terraform experience comes from then spent a stretch at Charter
            on a Next.js and PostgreSQL stack. I've freelanced on the side it
            since 2023.
          </p>
          <p>
            The work I enjoy most tends to sit at the seams, the SDK every
            team depends on, the data pipeline nobody remembers owning, the
            race condition nobody wanted to open. Those problems reward
            patience and usually teach you something load-bearing about the
            system.
          </p>
          <p>
            Recent side projects live in the <a href="/work/">work/</a> directory.
          </p>
        </div>
      </section>

      <section class="block">
        <h2 class="section-title"><span class="hash">##</span> experience</h2>
        <div class="content">
          <ol class="roles">
            {
              roles.map((role) => (
                <li class="role">
                  <div class="role-bullet" aria-hidden="true">▸</div>
                  <div class="role-main">
                    <p class="role-title">
                      {role.title} <span class="role-sep">@</span>{" "}
                      <span class="role-company">{role.company}</span>
                    </p>
                    <p class="role-period">{role.period}</p>
                    <p class="role-summary">{role.summary}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section class="block">
        <h2 class="section-title"><span class="hash">##</span> education</h2>
        <div class="content">
          <ol class="roles">
            {
              education.map((item) => (
                <li class="role">
                  <div class="role-bullet" aria-hidden="true">▸</div>
                  <div class="role-main">
                    <p class="role-title">
                      {item.degree} <span class="role-sep">@</span>{" "}
                      <span class="role-company">{item.institution}</span>
                    </p>
                    <p class="role-period">{item.year}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section class="block">
        <h2 class="section-title"><span class="hash">##</span> mentoring</h2>
        <div class="content">
          <ol class="roles">
            {
              mentoring.map((item) => (
                <li class="role">
                  <div class="role-bullet" aria-hidden="true">▸</div>
                  <div class="role-main">
                    <p class="role-title">{item.title}</p>
                    <p class="role-period">{item.period}</p>
                    <p class="role-summary">{item.detail}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section class="block">
        <h2 class="section-title"><span class="hash">##</span> skills</h2>
        <div class="content">
          <dl class="skill-groups">
            {
              skillGroups.map((group) => (
                <div class="skill-group">
                  <dt>{group.label}</dt>
                  <dd>
                    {group.items.map((item, i) => (
                      <>
                        {i > 0 && <span class="sep">·</span>}
                        <span class="item">{item}</span>
                      </>
                    ))}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>
      </section>
    </main>

    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .about { max-width: 70rem; }

  .head h1 {
    font-size: var(--text-3xl);
    color: var(--fg-bright);
  }
  .tagline { color: var(--fg-dim); max-width: 60ch; }

  .portrait-frame {
    border: 1px solid var(--rule);
    background: var(--bg-elev);
    margin-top: 0.75rem;
  }
  .portrait-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-window-bar);
    border-bottom: 1px solid var(--rule);
    padding: 0.4rem 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg-dim);
  }
  .portrait-frame :global(picture),
  .portrait-frame :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
  .portrait-frame :global(img) {
    object-fit: cover;
  }
  :root.theme-dark .portrait-frame :global(img) {
    filter: contrast(1.04) saturate(0.85) brightness(0.92);
  }

  .block { display: flex; flex-direction: column; gap: 0.75rem; }
  .section-title {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--fg-bright);
  }
  .hash { color: var(--phosphor-soft); }

  .content p + p { margin-top: 0.75rem; }

  .roles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .role {
    display: grid;
    grid-template-columns: 1.25rem 1fr;
    gap: 0.5rem;
  }
  .role-bullet { color: var(--phosphor-soft); }
  .role-main { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .role-title { color: var(--fg-bright); font-weight: 600; }
  .role-sep { color: var(--fg-mute); font-weight: 400; }
  .role-company { color: var(--cyan); font-weight: 500; }
  .role-period { color: var(--amber); font-size: var(--text-sm); }
  .role-summary { color: var(--fg-dim); font-size: var(--text-sm); }

  .skill-groups {
    display: grid;
    gap: 0.6rem;
    margin: 0;
  }
  .skill-group {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.4rem 0;
    border-bottom: 1px dashed var(--rule);
  }
  .skill-group:last-child { border-bottom: 0; }
  .skill-group dt {
    color: var(--phosphor-soft);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .skill-group dt::before { content: "$ "; color: var(--fg-mute); }
  .skill-group dd { margin: 0; color: var(--fg); }
  .skill-group .item { color: var(--fg-bright); }
  .skill-group .sep { color: var(--fg-mute); margin: 0 0.5ch; }

  @media (max-width: 49.99em) {
    .skill-group {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
