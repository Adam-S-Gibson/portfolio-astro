---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 Not Found" description="404 Error — page not found">
  <main class="wrapper notfound stack gap-4">
    <p class="term-prompt">
      <span class="u">adam</span><span class="s">@</span><span class="h">portfolio</span><span class="s">:</span><span class="p">~</span> <span class="c">$</span> cat {Astro.url.pathname}
    </p>
    <p class="err">cat: <span class="path">{Astro.url.pathname}</span>: No such file or directory</p>
    <p class="rc">exit code: <span class="code">127</span></p>
    <p class="term-prompt">
      <span class="u">adam</span><span class="s">@</span><span class="h">portfolio</span><span class="s">:</span><span class="p">~</span> <span class="c">$</span> cd /<span class="cursor"></span>
    </p>
    <p class="back"><a href="/">&rarr; back to ~</a></p>
  </main>
</BaseLayout>

<style>
  .notfound {
    min-height: 50vh;
    padding-top: 3rem;
    font-family: var(--font-mono);
  }
  .err { color: var(--red); }
  .path { color: var(--fg-bright); }
  .rc { color: var(--fg-dim); font-size: var(--text-sm); }
  .code { color: var(--amber); }
  .back a { color: var(--phosphor-soft); }
</style>
